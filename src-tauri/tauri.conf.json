{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "walltch",
	"version": "0.1.0",
	"identifier": "com.walltch.app",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Walltch",
				"width": 1280,
				"height": 800,
				"minWidth": 960,
				"minHeight": 600,
				"transparent": true,
				"decorations": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"resources": ["lib/**/*"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
